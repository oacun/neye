# ===========================================
# КОНФИГУРАЦИЯ ИГОЛЬНОГО УШКА
# ===========================================

# Режим работы (development или production)
NODE_ENV=development

# Порт сервера
PORT=3000

# ===========================================
# БЕЗОПАСНОСТЬ
# ===========================================

# Секретный ключ для сессий (ОБЯЗАТЕЛЬНО ИЗМЕНИТЬ В PRODUCTION!)
# Генерируйте длинный случайный ключ минимум 32 символа
SESSION_SECRET=your-very-long-random-secret-key-here-change-in-production

# ===========================================
# EMAIL (для восстановления пароля)
# ===========================================

# SMTP настройки
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Email отправителя
EMAIL_FROM=noreply@igolnoe-ushko.ru

# URL вашего сайта (для ссылок в письмах)
SITE_URL=http://localhost:3000

# ===========================================
# reCAPTCHA
# ===========================================

# Google reCAPTCHA v2 secret key
RECAPTCHA_SECRET_KEY=your-recaptcha-secret-key

# ===========================================
# ЛОГИРОВАНИЕ
# ===========================================

# Уровень логирования (error, warn, info, debug)
LOG_LEVEL=info

# ===========================================
# ПРИМЕЧАНИЯ
# ===========================================

# Gmail SMTP:
# 1. Включите двухфакторную аутентификацию в Google Account
# 2. Создайте "Пароль приложения" в настройках безопасности
# 3. Используйте этот пароль в SMTP_PASS

# Генерация SESSION_SECRET:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"

# reCAPTCHA:
# Получите ключи на https://www.google.com/recaptcha/admin
